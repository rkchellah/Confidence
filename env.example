# Confidence — environment variables
# Copy this file to .env.local and fill in real values
# .env.local is in .gitignore — never commit it

# ─── Perfect Corp ──────────────────────────────────────────────────────────────
# Get your key at: https://yce.makeupar.com/api-console/en/api-keys/
# Confirm skin-analysis endpoint is available on your tier before starting
PERFECTCORP_API_KEY=

# ─── Voyage AI (embeddings — primary) ─────────────────────────────────────────
# Get your key at: https://dash.voyageai.com
# Free tier for new users — verify current limits at https://docs.voyageai.com/docs/pricing
VOYAGE_API_KEY=

# ─── GROQ ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — safe to expose in logs, not in frontend HTML
SUPABASE_URL=

# Service role key — bypasses RLS, never expose to frontend or commit to repo
SUPABASE_KEY=

# ─── Config ────────────────────────────────────────────────────────────────────
# How long to poll Perfect Corp before giving up (seconds)
POLL_TIMEOUT_SECONDS=30
