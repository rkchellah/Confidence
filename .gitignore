# Confidence — .gitignore

# ─── Secrets — never commit these ─────────────────────────────────────────────
.env.local
.env
.env.*.local

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Uploads / temp files ─────────────────────────────────────────────────────
uploads/
tmp/
*.tmp

# ─── Render ───────────────────────────────────────────────────────────────────
.render-buildpacks.json
